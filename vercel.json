{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "BASE_PATH=/ PORT=3000 pnpm --filter @workspace/route-mapper run build && cp -r artifacts/route-mapper/dist/public ./dist",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
