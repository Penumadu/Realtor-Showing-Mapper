rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Routes collection security rules
    match /routes/{routeId} {
      // Allow read or delete if the user is authenticated and is the owner
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Allow create if the user is authenticated and sets themselves as the owner
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Allow update if the user is authenticated, is the owner, and doesn't change the owner ID
      allow update: if request.auth != null 
        && resource.data.userId == request.auth.uid 
        && request.resource.data.userId == request.auth.uid;
    }
  }
}
